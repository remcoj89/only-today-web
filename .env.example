# Alleen voor lokaal/CI. Zie docs/DEPLOYMENT.md voor productie.

# Verplicht: canonieke URL van de frontend
PUBLIC_WEB_URL=http://localhost:3001
# Of gebruik PUBLIC_APP_URL (backward compatibility)

# Optioneel: API base URL (valt anders terug op PUBLIC_WEB_URL)
# PUBLIC_API_URL=

# Verplicht: Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optioneel
# PUBLIC_GTM_ID=
# PUBLIC_DEFAULT_LOCALE=nl
